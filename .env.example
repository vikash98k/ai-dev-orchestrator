# GitHub Fine-Grained Personal Access Token
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=your_github_fine_grained_token_here

# Target repository (dynamic — change these to point at any repo)
GITHUB_OWNER=vikash98k
GITHUB_REPO=fashion-store-backend

# GitHub Project V2 number (from the project URL)
GITHUB_PROJECT_NUMBER=6

# Local Git workspace root (clones land in $WORKSPACE_ROOT/<repo>)
WORKSPACE_ROOT=~/workspace

# Optional override for the branch updated before feature branching
# (defaults to the repository default branch when unset)
# GIT_DEFAULT_BRANCH=develop
